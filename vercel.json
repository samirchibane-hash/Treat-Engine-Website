{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js",       "use": "@vercel/node" },
    { "src": "*.html",            "use": "@vercel/static" },
    { "src": "checkout/*.html",   "use": "@vercel/static" },
    { "src": "onboarding/*.html", "use": "@vercel/static" },
    { "src": "admin/*.html",      "use": "@vercel/static" },
    { "src": "booking-confirmed.html", "use": "@vercel/static" },
    { "src": "blog.html",             "use": "@vercel/static" },
    { "src": "blog/*.html",           "use": "@vercel/static" },
    { "src": "images/**",         "use": "@vercel/static" },
    { "src": "logos/**",          "use": "@vercel/static" },
    { "src": "uploads/**",        "use": "@vercel/static" },
    { "src": "*.png",             "use": "@vercel/static" },
    { "src": "*.jpg",             "use": "@vercel/static" },
    { "src": "*.webp",            "use": "@vercel/static" },
    { "src": "*.css",             "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/checkout",          "dest": "/api/checkout.js" },
    { "src": "/api/webhook",           "dest": "/api/webhook.js" },
    { "src": "/api/verify-session",    "dest": "/api/verify-session.js" },
    { "src": "/api/onboarding",        "dest": "/api/onboarding.js" },
    { "src": "/api/admin/login",       "dest": "/api/admin/login.js" },
    { "src": "/api/admin/customers",   "dest": "/api/admin/customers.js" },
    { "src": "/",                      "dest": "/Home.html" },
    { "src": "/home",                  "dest": "/Home.html" },
    { "src": "/ads",                   "dest": "/Water%20Leads.html" },
    { "src": "/ads/checkout",          "dest": "/checkout/leads.html" },
    { "src": "/ads/onboarding",        "dest": "/onboarding/leads.html" },
    { "src": "/booking",               "dest": "/Water%20Leads%20Booking.html" },
    { "src": "/sales",                 "dest": "/Water%20Sales.html" },
    { "src": "/sales/checkout",        "dest": "/checkout/sales.html" },
    { "src": "/sales/onboarding",      "dest": "/onboarding/sales.html" },
    { "src": "/websites",              "dest": "/Water%20Websites.html" },
    { "src": "/websites/checkout",     "dest": "/checkout/websites.html" },
    { "src": "/websites/onboarding",   "dest": "/onboarding/websites.html" },
    { "src": "/admin",                 "dest": "/admin/index.html" },
    { "src": "/admin/login",           "dest": "/admin/login.html" },
    { "src": "/booking-confirmed",     "dest": "/booking-confirmed.html" },
    { "src": "/blog",                  "dest": "/blog.html" },
    { "src": "/blog/water-treatment-in-home-sales-tool-value-comparison", "dest": "/blog/water-treatment-in-home-sales-tool-value-comparison.html" },
    { "src": "/blog/strategies-for-profitable-water-softener-facebook-ads-in-2026", "dest": "/blog/strategies-for-profitable-water-softener-facebook-ads-in-2026.html" },
    { "src": "/blog/high-roi-water-softener-facebook-ad-campaigns", "dest": "/blog/high-roi-water-softener-facebook-ad-campaigns.html" },
    { "src": "/blog/5-secrets-to-water-treatment-system-sales-with-social-media-ads", "dest": "/blog/5-secrets-to-water-treatment-system-sales-with-social-media-ads.html" },
    { "src": "/blog/7-lessons-from-water-softener-lead-gen-ads-on-facebook", "dest": "/blog/7-lessons-from-water-softener-lead-gen-ads-on-facebook.html" },
    { "src": "/blog/fix-unprofitable-water-softener-advertising-campaigns", "dest": "/blog/fix-unprofitable-water-softener-advertising-campaigns.html" },
    { "src": "/blog/automate-your-water-treatment-marketing-in-2025", "dest": "/blog/automate-your-water-treatment-marketing-in-2025.html" },
    { "src": "/v1",                    "dest": "/index%20v1.html" },
    { "src": "/(.*)",                  "dest": "/$1" }
  ]
}
