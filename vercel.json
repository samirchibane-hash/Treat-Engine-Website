{
  "version": 2,
  "buildCommand": null,
  "outputDirectory": ".",
  "routes": [
    { "src": "/",         "dest": "/index.html" },
    { "src": "/home",     "dest": "/Home.html" },
    { "src": "/ads",      "dest": "/Water%20Leads%20Ads.html" },
    { "src": "/booking",  "dest": "/Water%20Leads%20Booking.html" },
