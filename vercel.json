{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js",       "use": "@vercel/node" },
    { "src": "*.html",            "use": "@vercel/static" },
    { "src": "checkout/*.html",   "use": "@vercel/static" },
    { "src": "onboarding/*.html", "use": "@vercel/static" },
    { "src": "admin/*.html",      "use": "@vercel/static" },
    { "src": "images/**",         "use": "@vercel/static" },
    { "src": "logos/**",          "use": "@vercel/static" },
    { "src": "uploads/**",        "use": "@vercel/static" },
    { "src": "*.png",             "use": "@vercel/static" },
    { "src": "*.jpg",             "use": "@vercel/static" },
    { "src": "*.webp",            "use": "@vercel/static" },
    { "src": "*.css",             "use": "@vercel/static" },
    { "src": "*.js",              "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/",                    "destination": "/Home.html" },
    { "source": "/home",                "destination": "/Home.html" },
    { "source": "/ads",                 "destination": "/Water%20Leads.html" },
    { "source": "/ads/checkout",        "destination": "/checkout/leads.html" },
    { "source": "/ads/onboarding",      "destination": "/onboarding/leads.html" },
    { "source": "/booking",             "destination": "/Water%20Leads%20Booking.html" },
    { "source": "/sales",               "destination": "/Water%20Sales.html" },
    { "source": "/sales/checkout",      "destination": "/checkout/sales.html" },
    { "source": "/sales/onboarding",    "destination": "/onboarding/sales.html" },
    { "source": "/websites",            "destination": "/Water%20Websites.html" },
    { "source": "/websites/checkout",   "destination": "/checkout/websites.html" },
    { "source": "/websites/onboarding", "destination": "/onboarding/websites.html" },
    { "source": "/admin",               "destination": "/admin/index.html" },
    { "source": "/admin/login",         "destination": "/admin/login.html" },
    { "source": "/v1",                  "destination": "/index%20v1.html" }
  ]
}
