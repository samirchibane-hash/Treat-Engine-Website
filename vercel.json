{
  "version": 2,
  "builds": [
    { "src": "*.html",        "use": "@vercel/static" },
    { "src": "*.png",         "use": "@vercel/static" },
    { "src": "*.webp",        "use": "@vercel/static" },
    { "src": "*.jpg",         "use": "@vercel/static" },
    { "src": "*.js",          "use": "@vercel/static" },
    { "src": "*.jsx",         "use": "@vercel/static" },
    { "src": "*.css",         "use": "@vercel/static" },
    { "src": "images/**",     "use": "@vercel/static" },
    { "src": "logos/**",      "use": "@vercel/static" },
    { "src": "uploads/**",    "use": "@vercel/static" },
    { "src": "screenshots/**","use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/",         "dest": "/Home.html" },
    { "src": "/home",     "dest": "/Home.html" },
    { "src": "/ads",      "dest": "/Water%20Leads.html" },
    { "src": "/booking",  "dest": "/Water%20Leads%20Booking.html" },
    { "src": "/sales",    "dest": "/Water%20Sales.html" },
    { "src": "/websites", "dest": "/Water%20Websites.html" },
    { "src": "/v1",       "dest": "/index%20v1.html" },
    { "src": "/(.*)",     "dest": "/$1" }
  ]
}
