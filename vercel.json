{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js",       "use": "@vercel/node" },
    { "src": "*.html",            "use": "@vercel/static" },
    { "src": "onboarding/*.html", "use": "@vercel/static" },
    { "src": "checkout/*.html",   "use": "@vercel/static" },
    { "src": "admin/*.html",      "use": "@vercel/static" },
    { "src": "*.png",             "use": "@vercel/static" },
    { "src": "*.webp",            "use": "@vercel/static" },
    { "src": "*.jpg",             "use": "@vercel/static" },
    { "src": "*.js",              "use": "@vercel/static" },
    { "src": "*.jsx",             "use": "@vercel/static" },
    { "src": "*.css",             "use": "@vercel/static" },
    { "src": "images/**",         "use": "@vercel/static" },
    { "src": "logos/**",          "use": "@vercel/static" },
    { "src": "uploads/**",        "use": "@vercel/static" },
    { "src": "screenshots/**",    "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)",              "dest": "/api/$1" },
    { "src": "/",                      "dest": "/Home.html" },
    { "src": "/home",                  "dest": "/Home.html" },
    { "src": "/ads",                   "dest": "/Water%20Leads.html" },
    { "src": "/ads/checkout",           "dest": "/checkout/leads.html" },
    { "src": "/ads/onboarding",        "dest": "/onboarding/leads.html" },
    { "src": "/booking",               "dest": "/Water%20Leads%20Booking.html" },
    { "src": "/sales",                 "dest": "/Water%20Sales.html" },
    { "src": "/sales/checkout",        "dest": "/checkout/sales.html" },
    { "src": "/sales/onboarding",      "dest": "/onboarding/sales.html" },
    { "src": "/websites",              "dest": "/Water%20Websites.html" },
    { "src": "/websites/checkout",     "dest": "/checkout/websites.html" },
    { "src": "/websites/onboarding",   "dest": "/onboarding/websites.html" },
    { "src": "/admin",                 "dest": "/admin/index.html" },
    { "src": "/admin/login",           "dest": "/admin/login.html" },
    { "src": "/v1",                    "dest": "/index%20v1.html" },
    { "src": "/(.*)",                  "dest": "/$1" }
  ]
}
